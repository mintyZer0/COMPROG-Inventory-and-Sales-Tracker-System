## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This file is a combination of the standard GitHub VisualStudio.gitignore
## and common .NET Core / .NET entries.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][In][32]/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
Log/
logs/

# Visual Studio 2015+ cache/options directory
.vs/
# Uncomment if using a compressed repo
#/.vs/

# Visual Studio 2017 auto-generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Cc]omputer[Nn]ame*/

# VS Code
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image recurse caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on interactive terminals
$RECYCLE.BIN/

# VS and NetBeans lock files
*.lock

# Rider
.idea/
*.sln.iml

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Config to restore to a specific directory
# **/MyPackages/

# AppSettings.json secrets
# appsettings.Development.json

# BROWSER-SPECIFIC FILES
# .DS_Store is for macOS
.DS_Store
